"medicine": {
  "title": "Medicine",

  "stages": {
    "early": {
      "weights": {
        "recall": 0.4,
        "basic_concepts": 0.25,
        "simple_clinical_links": 0.2,
        "clinical_reasoning_light": 0.1,
        "interpretation_basic": 0.05
      }
    },
    "mid": {
      "weights": {
        "recall": 0.2,
        "interpretation": 0.2,
        "clinical_reasoning": 0.25,
        "pathophysiology": 0.2,
        "initial_management": 0.15
      }
    },
    "advanced": {
      "weights": {
        "clinical_reasoning": 0.3,
        "management_strategy": 0.25,
        "interpretation": 0.2,
        "pathophysiology": 0.15,
        "contraindications": 0.1
      }
    }
  },

  "subject_type_matrix": {
  "anatomy": {
    "high": ["recall", "interpretation", "clinical_reasoning"],
    "medium": ["diagnosis"],
    "low": ["mechanism", "contraindication"]
  },
  "physiology": {
    "high": ["mechanism", "interpretation"],
    "medium": ["clinical_reasoning"],
    "low": ["contraindication", "next_step"]
  },
  "biochemistry": {
    "high": ["mechanism", "recall"],
    "medium": ["clinical_reasoning"],
    "low": ["next_step", "contraindication"]
  },
  "pathology": {
    "high": ["diagnosis", "mechanism"],
    "medium": ["interpretation", "clinical_reasoning", "risk_factor", "complication"],
    "low": ["contraindication"]
  },
  "pharmacology": {
    "high": ["contraindication", "side_effect", "mechanism"],
    "medium": ["next_step", "clinical_reasoning", "risk_factor"],
    "low": ["interpretation"]
  },
  "microbiology": {
    "high": ["recall", "mechanism", "diagnosis"],
    "medium": ["clinical_reasoning", "risk_factor"],
    "low": ["next_step"]
  },
  "clinical_medicine": {
    "high": ["diagnosis", "next_step", "management_strategy"],
    "medium": ["interpretation", "contraindication", "risk_factor"],
    "low": ["recall"]
  }
  }
  


  "generate_distractors": [
  "1. Identify correct answer",
  "2. Extract key features (symptoms, age, risk factors)",
  "3. Find similar conditions (same presentation)",
  "4. Add one contraindicated option",
  "5. Add one partially correct option",
  "6. Ensure all options are same category (diagnoses or drugs etc.)",
  "7. Remove obvious wrong answers"
  ],
  
  "Recall Patterns": [
  "Which of the following is TRUE regarding X?",
  "All of the following are correct EXCEPT:",
  "Which of the following is NOT associated with X?",
  "X is characterized by which of the following?",
  "The life cycle of X includes:"
  ],
  
  "Diagnosis Patterns": [
  "What is the most likely diagnosis?",
  "Which condition best explains this presentation?",
  "This patient most likely has:"
    ],
  "management_patterns": [
  "What is the next best step in management?",
  "What is the most appropriate initial treatment?",
  "What should be done first?",
  "What is the best management strategy?"
  ],

  "Mechanism Patterns": [
  "What is the underlying mechanism?",
  "Which pathway is most likely affected?",
  "This condition is caused by:",
  "What is the primary defect?"
  ]
  "Interpretation Patterns": [
  "What does this lab finding indicate?",
  "Interpret the following results:",
  "Which of the following best explains these findings?",
  "What is the significance of this ECG/lab?"
  ],
  "safety_patterns": [
  "Which of the following is contraindicated?",
  "Which drug should be avoided?",
  "What is the most dangerous option?",
  "Which of the following is NOT appropriate?"
  ],
  "Complications": [
  "What is the most likely complication?",
  "Which side effect is most associated with this drug?",
  "What is the most serious adverse effect?"
  ],

  "pattern_mapping": {
  "recall": "recall_patterns",
  "diagnosis": "diagnosis_patterns",
  "next_step": "management_patterns",
  "mechanism": "mechanism_patterns",
  "interpretation": "interpretation_patterns",
  "contraindication": "safety_patterns"
  },

  "difficulty_levels": ["easy", "moderate", "hard"],

  "response_style": {
    "tone": "professional",
    "structure": "clinical_vignette",
    "explanation_depth": "stepwise"
  },

  "excluded_methods": [
    "unclear_generalizations",
    "tricky_without_concept"
  ],

  "prompt_instructions": "Generate USMLE-style MCQs. Always include a clinical context, even for basic questions, but adjust complexity based on stage. Ensure one clear best answer and plausible distractors.",

  "few_shot_examples": [
    "Q: A 45-year-old man presents with right upper quadrant pain...\nWhat is the most likely diagnosis?\nA) ... B) ... C) ...\nExplanation: Step 1: Identify key symptom...\nStep 2: Eliminate distractors...\nFinal: Option A."
  ]
}
